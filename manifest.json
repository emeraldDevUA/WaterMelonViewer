
{
  "manifest_version": 3,
  "name": "Watermelon Viewer",
  "version": "0.0.1",
  "description": "This is our first extension, so Hello world!",

  "permissions": ["notifications", "storage", "downloads", "sidePanel", "activeTab", "scripting"],


  "action": {
    "default_icon": "public/logo_no_background.png"
  },
    "side_panel": {
      "default_path": "sidepanel.html"
    },


  "web_accessible_resources": [
    {
      "resources": ["res/Porsche911.obj"],
      "matches": ["chrome-extension://*/*"]
    }
  ],

  "background": {
    "service_worker": "src/chrome-plugin/background.js"
  },

  "content_scripts": [
    {
      "run_at": "document_start",
      "matches": ["<all_urls>"],
      "js": ["src/chrome-plugin/sidepanel.js"]
    }
  ]



}